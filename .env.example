NEXT_PUBLIC_APP_NAME="Europe TikTok B2B Video Learning Assistant"
APP_PORT=3002
DATABASE_URL="file:./data/app.example.db"
API_AUTH_TOKEN=""
OPENAI_API_KEY=""

# n8n Webhook URL - POST daily brief markdown to this URL
N8N_WEBHOOK_URL=""

# OpenClaw Webhook URL - POST daily brief markdown to this URL
OPENCLAW_WEBHOOK_URL=""

# Daily brief push time (for reference, actual scheduling done by n8n/cron)
DAILY_BRIEF_TIME="09:00"

# Enable automatic daily push (requires external scheduler like n8n)
ENABLE_DAILY_PUSH=false

ENABLE_AUTO_COLLECTION=false
ENABLE_PUBLIC_API=true
