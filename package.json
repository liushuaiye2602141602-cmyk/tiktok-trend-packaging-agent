{
  "name": "tiktok-trend-packaging-agent",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "db:seed": "node scripts/seed.mjs",
    "db:reset": "node -e \"const fs=require('fs');const p='data/db.json';if(fs.existsSync(p))fs.unlinkSync(p);console.log('Database cleared.');\" && npm run db:seed"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.0"
  }
}
